# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
# Sess79 PR-6c hotfix: trailing slash 削除で symlink (= worktree-init.sh の node_modules symlink) も ignore 対象に。
# 旧 `node_modules/` (trailing slash あり) は directory のみ ignore、 symlink は 対象外で commit に混入する罠あり
# (Sess79 PR-6 #999 で 循環 symlink commit 事故発生、 PR-6b #1000 で symlink 物理削除済、 本 PR で 構造防止)。
node_modules

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# secrets (EAS Submit service account keys, etc.)
secrets/

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# Tamagui generated
.tamagui/

# Debug sessions
.debug-sessions/

# Claude Code 一時ファイル
.claude/scheduled_tasks.lock

# Store screenshots output
screenshots/
# Whitelist: mockup v1.0 screenshots は写経駆動開発 (R-29) 参照用に commit する (T1-2)
!docs/mockups/v1.0/screenshots/
!docs/mockups/v1.0/screenshots/**

# UI diff output (ADR-0021)
scripts/ui-diff/out/*

# Whitelist: G0 PoC results template (ADR-0024 Phase G0、ユーザー実機検証結果記録)
!scripts/ui-diff/out/poc-g0/
!scripts/ui-diff/out/poc-g0/**

# OpenDesign チャット履歴 DB (ローカル参照のみ、ユーザープロンプト履歴を含む 4MB+ binary)
docs/mockups/v1.0/app.sqlite
docs/mockups/v1.0/app.sqlite-shm
docs/mockups/v1.0/app.sqlite-wal

# Sess 一時 capture (user 確認用 SS、commit 不要)
tmp-captures/

# Sess25 PR-ζ-2-② で誤コミット防止 (out/ は ui-diff / 検証 SS 用 ローカル output、 commit 不要)
out/

# Python bytecode cache (store-automation スクリプト)
__pycache__/
*.pyc
