{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["app/**/*.{ts,tsx}", "__tests__/**/*.{ts,tsx,js}"],
  "project": [
    "app/**/*.{ts,tsx}",
    "src/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "hooks/**/*.{ts,tsx}",
    "constants/**/*.{ts,tsx}"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["adb", "wslpath", "python3", "maestro"],
  "ignoreDependencies": [
    "expo-asset",
    "expo-updates",
    "@react-native/eslint-config",
    "@testing-library/jest-native",
    "eslint-config-prettier",
    "eslint-plugin-react",
    "eslint-plugin-react-hooks",
    "lint-staged",
    "ts-jest",
    "typescript-eslint"
  ],
  "ignore": ["hooks/use-color-scheme.web.ts"],
  "rules": {
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "duplicates": "warn",
    "enumMembers": "warn",
    "classMembers": "warn"
  }
}
