{
  "name": "bonsailog",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:e2e": "maestro test maestro/flows/smoke.yml",
    "i18n:audit": "node scripts/i18n-audit.mjs",
    "i18n:check": "node scripts/i18n-check.mjs",
    "i18n:forbidden": "node scripts/i18n-forbidden-words.mjs",
    "i18n:placeholder-audit": "node scripts/i18n-placeholder-audit.mjs",
    "i18n:add-key": "node scripts/i18n-add-key.mjs",
    "i18n:remove-key": "node scripts/i18n-remove-key.mjs",
    "i18n:apply": "node scripts/i18n/apply-translation.mjs",
    "lint:hardcode": "node scripts/check-hardcode-strings.mjs",
    "lint:destructive-undo": "node scripts/check-destructive-undo.mjs",
    "lint:discuss-jargon": "node scripts/check-discuss-jargon.mjs",
    "config:check": "node scripts/config-check.mjs",
    "docs:lint": "node scripts/docs-lint.mjs",
    "template:check": "node scripts/template-residue-check.mjs",
    "native:check": "node scripts/native-runtime-check.mjs",
    "theme:check": "node scripts/theme-legacy-check.mjs",
    "theme:tokens": "node scripts/theme-token-check.mjs",
    "theme:sot": "node scripts/theme-source-of-truth.mjs",
    "theme:form-typography": "node scripts/check-form-typography.mjs",
    "navigation:check": "node scripts/check-navigation-patterns.mjs",
    "a11y:contrast": "node scripts/a11y-contrast-check.mjs",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "verify:lint": "pnpm lint",
    "verify:type-check": "pnpm type-check",
    "verify:format": "pnpm format:check",
    "verify:test": "pnpm test",
    "verify:i18n": "pnpm i18n:check && pnpm i18n:forbidden",
    "verify:hardcode": "pnpm lint:hardcode",
    "verify:config": "pnpm config:check",
    "verify:docs": "pnpm docs:lint",
    "verify:template": "pnpm template:check",
    "verify:native": "pnpm native:check",
    "verify:theme": "pnpm theme:check && pnpm theme:tokens && pnpm theme:sot",
    "verify:a11y": "pnpm a11y:contrast",
    "verify:maestro": "node scripts/maestro-flow-lint.mjs",
    "verify:iteration": "node scripts/check-iteration-consistency.mjs",
    "verify:screen-testid": "node scripts/check-screen-testid.mjs",
    "verify:modal-autofocus": "node scripts/check-modal-autofocus.mjs",
    "verify:adr-sources": "node scripts/check-adr-sources.mjs",
    "verify": "pnpm verify:lint && pnpm verify:type-check && pnpm verify:format && pnpm verify:test && pnpm verify:i18n && pnpm verify:hardcode && pnpm verify:config && pnpm verify:docs && pnpm verify:template && pnpm verify:native && pnpm verify:theme && pnpm verify:a11y && pnpm verify:maestro && pnpm verify:iteration && pnpm verify:screen-testid && pnpm verify:modal-autofocus",
    "prepare": "git config core.hooksPath .githooks",
    "prebuild": "expo prebuild",
    "build:android": "expo prebuild --platform android && cd android && ./gradlew bundleRelease",
    "build:android:apk:local": "node scripts/prebuild-env-check.mjs android && npx eas-cli@latest build -p android --profile preview-local-apk --local --output dist/bonsailog-preview-local.apk && node scripts/postbuild-verify.mjs dist/bonsailog-preview-local.apk",
    "build:android:dev:local": "node scripts/prebuild-env-check.mjs android && npx eas-cli@latest build -p android --profile development --local --output dist/bonsailog-dev.apk && node scripts/postbuild-verify.mjs dist/bonsailog-dev.apk",
    "install:device": "adb install -r \"$(wslpath -w dist/bonsailog-preview-local.apk)\"",
    "install:device:dev": "adb install -r \"$(wslpath -w dist/bonsailog-dev.apk)\"",
    "build:android:aab:local": "node scripts/prebuild-env-check.mjs android && npx eas-cli@latest build -p android --profile production --local --output dist/app-production.aab && node scripts/postbuild-verify.mjs dist/app-production.aab",
    "metadata:check": "node scripts/validate-metadata.mjs",
    "mockup:serve": "python3 -m http.server 8082 -d docs/mockups/v1.0/wireframes",
    "mockup:screenshots": "tsx scripts/ui-diff/generate-mockup-screenshots.ts",
    "ui-diff:pairing-report": "node scripts/ui-diff/generate-pairing-report.mjs",
    "dev:android": "bash scripts/dev-start.sh",
    "ump:check": "node scripts/ump-consent-check.mjs",
    "debug:start": "bash scripts/debug/debug_session.sh start",
    "debug:stop": "bash scripts/debug/debug_session.sh stop",
    "debug:status": "bash scripts/debug/debug_session.sh status",
    "monitor": "bash scripts/debug/monitor.sh",
    "ai:sync": "node agent-tools/scripts/sync-agent-tools.mjs",
    "ai:doctor": "node agent-tools/scripts/check-agent-tools.mjs"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/noto-sans-jp": "^0.4.3",
    "@expo-google-fonts/noto-serif-jp": "^0.4.3",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/elements": "^2.9.15",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "^2.3.1",
    "@tamagui/animations-react-native": "1.144.3",
    "@tamagui/core": "1.144.3",
    "@tamagui/lucide-icons": "1.144.3",
    "@tamagui/portal": "1.144.3",
    "@tanstack/react-query": "^5.100.9",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "expo": "~55.0.9",
    "expo-build-properties": "^55.0.10",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.19",
    "expo-file-system": "^55.0.17",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-image": "~55.0.6",
    "expo-image-manipulator": "^55.0.15",
    "expo-image-picker": "^55.0.19",
    "expo-linking": "~55.0.9",
    "expo-localization": "~55.0.9",
    "expo-notifications": "^55.0.14",
    "expo-print": "^55.0.13",
    "expo-router": "~55.0.8",
    "expo-secure-store": "^55.0.9",
    "expo-sharing": "^55.0.18",
    "expo-splash-screen": "~55.0.19",
    "expo-sqlite": "^55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-store-review": "~55.0.9",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.11",
    "expo-tracking-transparency": "~55.0.13",
    "expo-web-browser": "~55.0.10",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-get-random-values": "^2.0.0",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-purchases": "^10.0.1",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-webview": "^13.16.0",
    "react-native-worklets": "0.7.2",
    "react-native-zip-archive": "7.0.2",
    "tamagui": "1.144.3",
    "ulid": "^3.0.2",
    "valibot": "^1.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.82.1",
    "@tamagui/babel-plugin": "1.144.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "lint-staged": "^16.1.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.5",
    "sharp": "^0.34.5",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "app/**/*.{ts,tsx}",
      "!src/core/i18n/locales/**",
      "!**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 20
      }
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|native-base|react-native-svg|@tanstack/.*|zustand|tamagui|@tamagui/.*)"
    ]
  },
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "react-native-zip-archive": "7.0.2"
    }
  },
  "private": true
}
