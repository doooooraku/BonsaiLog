{
  "name": "bonsailog",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:e2e": "maestro test maestro/flows/smoke.yml",
    "i18n:audit": "node scripts/i18n-audit.mjs",
    "i18n:check": "node scripts/i18n-check.mjs",
    "i18n:forbidden": "node scripts/i18n-forbidden-words.mjs",
    "i18n:placeholder-audit": "node scripts/i18n-placeholder-audit.mjs",
    "i18n:add-key": "node scripts/i18n-add-key.mjs",
    "i18n:remove-key": "node scripts/i18n-remove-key.mjs",
    "i18n:style": "node scripts/i18n-style-ja.mjs",
    "i18n:unused": "node scripts/i18n-unused-keys.mjs",
    "i18n:apply": "node scripts/i18n/apply-translation.mjs",
    "lint:hardcode": "node scripts/check-hardcode-strings.mjs",
    "lint:destructive-undo": "node scripts/check-destructive-undo.mjs",
    "lint:discuss-jargon": "node scripts/check-discuss-jargon.mjs",
    "lint:icon-duplication": "node scripts/check-icon-duplication.mjs",
    "lint:utc-date-slice": "node scripts/check-utc-date-slice.mjs",
    "config:check": "node scripts/config-check.mjs",
    "docs:lint": "node scripts/docs-lint.mjs",
    "harness:metrics": "node scripts/harness-metrics.mjs",
    "metrics:doc-baseline": "node scripts/dev/analyze-doc-reads.mjs",
    "metrics:doc-30day-zero": "node scripts/dev/analyze-doc-reads-30day.mjs",
    "metrics:doc-freshness": "node scripts/doc-freshness-check.mjs",
    "template:check": "node scripts/template-residue-check.mjs",
    "native:check": "node scripts/native-runtime-check.mjs",
    "theme:check": "node scripts/theme-legacy-check.mjs",
    "theme:tokens": "node scripts/theme-token-check.mjs",
    "theme:sot": "node scripts/theme-source-of-truth.mjs",
    "theme:form-typography": "node scripts/check-form-typography.mjs",
    "navigation:check": "node scripts/check-navigation-patterns.mjs",
    "a11y:contrast": "node scripts/a11y-contrast-check.mjs",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "verify:lint": "pnpm lint",
    "verify:type-check": "pnpm type-check",
    "verify:format": "pnpm format:check",
    "verify:test": "pnpm test",
    "verify:i18n": "pnpm i18n:check && pnpm i18n:forbidden && node scripts/i18n-style-ja.mjs --strict",
    "verify:hardcode": "pnpm lint:hardcode",
    "verify:config": "pnpm config:check",
    "verify:docs": "pnpm docs:lint",
    "verify:template": "pnpm template:check",
    "verify:metadata": "pnpm metadata:check",
    "verify:native": "pnpm native:check",
    "verify:theme": "pnpm theme:check && pnpm theme:tokens && pnpm theme:sot",
    "verify:a11y": "pnpm a11y:contrast",
    "verify:iteration": "node scripts/check-iteration-consistency.mjs",
    "verify:screen-testid": "node scripts/check-screen-testid.mjs",
    "verify:modal-autofocus": "node scripts/check-modal-autofocus.mjs",
    "verify:form-screen-scroll": "node scripts/check-form-screen-scroll.mjs",
    "verify:icon-duplication": "pnpm lint:icon-duplication",
    "verify:utc-date-slice": "pnpm lint:utc-date-slice",
    "verify:event-type-consistency": "node scripts/check-event-type-consistency.mjs",
    "scaffold:event-type": "node scripts/scaffold-event-type.mjs",
    "verify:adr-sources": "node scripts/check-adr-sources.mjs",
    "verify:screen-header-typography": "node scripts/dev/check-screen-header-typography.mjs",
    "verify:stack-screen-title": "node scripts/dev/check-stack-screen-title.mjs",
    "verify:manager-screen-symmetry": "node scripts/dev/check-manager-screen-symmetry.mjs",
    "verify:i18n-icon-duplicate": "node scripts/check-i18n-icon-duplicate.mjs",
    "knip:check": "knip",
    "verify:dead": "knip --no-exit-code",
    "verify:ai-sync": "node agent-tools/scripts/sync-agent-tools.mjs --check",
    "gen:doc-routing": "node scripts/gen-doc-routing.mjs",
    "verify:doc-routing": "node scripts/gen-doc-routing.mjs --check",
    "verify:node": "node scripts/dev/check-node-version.mjs",
    "verify:hooks": "node scripts/dev/check-hooks.mjs --check",
    "r:next": "node scripts/dev/next-r-number.mjs",
    "verify": "pnpm verify:node && pnpm verify:hooks && pnpm verify:lint && pnpm verify:type-check && pnpm verify:format && pnpm verify:test && pnpm verify:i18n && pnpm verify:hardcode && pnpm verify:config && pnpm verify:docs && pnpm verify:template && pnpm verify:metadata && pnpm verify:native && pnpm verify:theme && pnpm verify:a11y && pnpm verify:iteration && pnpm verify:screen-testid && pnpm verify:modal-autofocus && pnpm verify:form-screen-scroll && pnpm verify:icon-duplication && pnpm verify:utc-date-slice && pnpm verify:event-type-consistency && pnpm verify:screen-header-typography && pnpm verify:stack-screen-title && pnpm verify:manager-screen-symmetry && pnpm verify:i18n-icon-duplicate && pnpm verify:ai-sync && pnpm verify:doc-routing && pnpm verify:dead && node scripts/dev/record-verify-state.mjs",
    "prepare": "git config core.hooksPath .githooks && node scripts/dev/check-hooks.mjs --quiet",
    "prebuild": "expo prebuild",
    "build:android": "expo prebuild --platform android && cd android && ./gradlew bundleRelease",
    "build:android:apk:local": "node scripts/guard-local-build.mjs && node scripts/prebuild-env-check.mjs android && npx eas-cli@latest build -p android --profile preview-local-apk --local --output dist/bonsailog-preview-local.apk && node scripts/postbuild-verify.mjs dist/bonsailog-preview-local.apk",
    "build:android:dev:local": "node scripts/guard-local-build.mjs && node scripts/prebuild-env-check.mjs android && npx eas-cli@latest build -p android --profile development --local --output dist/bonsailog-dev.apk && node scripts/postbuild-verify.mjs dist/bonsailog-dev.apk",
    "install:device": "adb install -r \"$(wslpath -w dist/bonsailog-preview-local.apk)\"",
    "install:device:dev": "adb install -r \"$(wslpath -w dist/bonsailog-dev.apk)\"",
    "build:android:aab:local": "node scripts/guard-local-build.mjs && node scripts/prebuild-env-check.mjs android && npx eas-cli@latest build -p android --profile production --local --output dist/app-production.aab && node scripts/postbuild-verify.mjs dist/app-production.aab",
    "submit:android": "npx eas-cli@latest submit -p android --path dist/app-production.aab --profile production --non-interactive --no-wait",
    "release:android": "bash scripts/release-android-orchestrate.sh",
    "release:android:dry-run": "node scripts/preflight-android-release.mjs",
    "preflight:android": "node scripts/preflight-android-release.mjs",
    "preflight:android:ci": "node scripts/preflight-android-release.mjs --ci",
    "preflight:android:fix": "node scripts/preflight-android-release.mjs --auto-fix",
    "metadata:check": "node scripts/validate-metadata.mjs",
    "mockup:serve": "python3 -m http.server 8082 -d docs/mockups/v1.0/wireframes",
    "mockup:screenshots": "tsx scripts/mockups/generate-mockup-screenshots.ts",
    "dev:android": "bash scripts/dev-start.sh",
    "ump:check": "node scripts/ump-consent-check.mjs",
    "debug:start": "bash scripts/debug/debug_session.sh start",
    "debug:stop": "bash scripts/debug/debug_session.sh stop",
    "debug:status": "bash scripts/debug/debug_session.sh status",
    "monitor": "bash scripts/debug/monitor.sh",
    "ai:sync": "node agent-tools/scripts/sync-agent-tools.mjs",
    "ai:doctor": "node agent-tools/scripts/check-agent-tools.mjs"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/noto-sans-jp": "^0.4.3",
    "@expo-google-fonts/noto-serif-jp": "^0.4.3",
    "@expo/dom-webview": "56.0.5",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "expo": "~56.0.11",
    "expo-build-properties": "^56.0.18",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-file-system": "^56.0.8",
    "expo-font": "~56.0.6",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-image-manipulator": "^56.0.18",
    "expo-image-picker": "^56.0.17",
    "expo-linking": "~56.0.14",
    "expo-localization": "~56.0.6",
    "expo-notifications": "^56.0.17",
    "expo-print": "^56.0.4",
    "expo-router": "~56.2.10",
    "expo-secure-store": "^56.0.4",
    "expo-sharing": "^56.0.17",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "^56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-store-review": "~56.0.3",
    "expo-system-ui": "~56.0.5",
    "expo-tracking-transparency": "~56.0.5",
    "expo-web-browser": "^56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-get-random-values": "^1.11.0",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-purchases": "^10.0.1",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-webview": "^13.16.1",
    "react-native-worklets": "0.8.3",
    "react-native-zip-archive": "7.0.2",
    "rrule": "^2.8.1",
    "ulid": "^3.0.2",
    "valibot": "^1.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.82.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "eslint-config-expo": "~56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "knip": "^6.14.2",
    "lint-staged": "^16.1.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.3",
    "sharp": "^0.34.5",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEach": [],
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/__tests__/helpers/",
      "<rootDir>/.claude/worktrees/",
      "<rootDir>/__tests__/services/legalService.test.ts",
      "<rootDir>/__tests__/core/hooks/useUnsavedChangesGuard.test.ts",
      "<rootDir>/__tests__/scripts/check-native-impact.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "app/**/*.{ts,tsx}",
      "!src/core/i18n/locales/**",
      "!**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 20
      }
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|expo-.*|standard-navigation|react-navigation|@react-navigation/.*|native-base|react-native-svg|zustand)"
    ]
  },
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "react-native-zip-archive": "7.0.2",
      "@expo/dom-webview": "56.0.5",
      "@expo/metro-runtime": "56.0.15",
      "@expo/log-box": "56.0.13"
    }
  },
  "private": true
}
