# =============================================================================
# App Identity (REQUIRED - fail fast if missing)
# =============================================================================
APP_NAME=BonsaiLog
APP_SLUG=bonsailog
IOS_BUNDLE_IDENTIFIER=com.dooooraku.bonsailog
ANDROID_PACKAGE=com.dooooraku.bonsailog

# =============================================================================
# EAS (Expo Application Services)
# =============================================================================
EAS_PROJECT_ID=
EAS_OWNER=

# =============================================================================
# AdMob
# =============================================================================
ADMOB_ANDROID_APP_ID=
ADMOB_IOS_APP_ID=
ADMOB_ANDROID_BANNER_ID=
ADMOB_IOS_BANNER_ID=
ADMOB_CONSENT_DEBUG_GEOGRAPHY=
ADMOB_CONSENT_TEST_DEVICE_IDS=

# =============================================================================
# RevenueCat (Sess81 R-68: 外部サービス連携 ADR は preflight smoke test 配線必須)
# =============================================================================
# Public API keys (取得: https://app.revenuecat.com/projects/<id>/apps/<id>/api-keys)
# ⚠ 接頭辞を取り違えると Purchases.getOfferings() が null を返し、 Paywall「利用不可」
#   になります (prebuild-env-check.mjs Layer 1.7 で接頭辞 verify 済)。
#
# Android: 必ず goog_xxxxx で始まる (e.g., goog_optOZkjhYkevkc...)
# iOS    : 必ず appl_xxxxx で始まる (e.g., appl_cWMoUCtrVolSYCA...)
REVENUECAT_ANDROID_API_KEY=
REVENUECAT_IOS_API_KEY=
IAP_DEBUG=0

# =============================================================================
# Legal URLs (fallback defaults used if empty)
# =============================================================================
LEGAL_PRIVACY_URL=
LEGAL_TERMS_URL=

# =============================================================================
# RTL Support
# =============================================================================
SUPPORTS_RTL=0
FORCES_RTL=0

# =============================================================================
# Sentry (Error Monitoring)
# =============================================================================
SENTRY_DSN=
